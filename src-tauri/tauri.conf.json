{
  "$schema": "https://raw.githubusercontent.com/nicoverbruggen/tauri-schema/refs/heads/v2/schema.json",
  "productName": "NightFlow",
  "version": "0.1.0",
  "identifier": "com.nightflow.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "bun run dev",
    "beforeBuildCommand": "bun run build"
  },
  "bundle": {
    "active": true,
    "targets": ["dmg", "app"],
    "icon": [
      "icons/32x32.png",
      "icons/64x64.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico",
      "icons/icon.png"
    ]
  },
  "app": {
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "",
        "width": 1200,
        "height": 800,
        "visible": false,
        "maximized": true,
        "decorations": true,
        "titleBarStyle": "Overlay",
        "hiddenTitle": true
      },
      {
        "label": "splashscreen",
        "url": "splashscreen.html",
        "width": 400,
        "height": 400,
        "decorations": false,
        "transparent": true,
        "alwaysOnTop": true,
        "center": true,
        "resizable": false
      }
    ],
    "security": {
      "csp": null
    }
  }
}
